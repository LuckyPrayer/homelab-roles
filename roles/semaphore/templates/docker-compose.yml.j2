services:
  semaphore:
    image: {{ semaphore_image }}
    container_name: {{ semaphore_container_name }}
    env_file:
      - .env
{% if semaphore_traefik_enabled %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.semaphore.rule=Host(`{{ semaphore_hostname }}`)"
      - "traefik.http.routers.semaphore.entrypoints=websecure"
      - "traefik.http.routers.semaphore.tls.certresolver={{ semaphore_traefik_certresolver }}"
      - "traefik.http.services.semaphore.loadbalancer.server.port={{ semaphore_port }}"
{% endif %}
    # Host networking is required for Semaphore to SSH to target hosts
    # on the local VLAN. Semaphore listens on semaphore_port directly.
    network_mode: host
    volumes:
      - {{ semaphore_data_dir }}:/data
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:{{ semaphore_port }}/api/ping"]
      interval: {{ semaphore_healthcheck_interval }}
      timeout: {{ semaphore_healthcheck_timeout }}
      retries: {{ semaphore_healthcheck_retries }}
      start_period: {{ semaphore_healthcheck_start_period }}
    restart: unless-stopped
