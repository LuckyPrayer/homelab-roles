# Semaphore environment configuration
# Generated by Ansible - do not edit manually

# Database (BoltDB)
SEMAPHORE_DB_DIALECT={{ semaphore_db_dialect }}
SEMAPHORE_DB_HOST={{ semaphore_db_path }}

# Admin user
SEMAPHORE_ADMIN={{ semaphore_admin_user }}
SEMAPHORE_ADMIN_NAME={{ semaphore_admin_name }}
SEMAPHORE_ADMIN_EMAIL={{ semaphore_admin_email }}
SEMAPHORE_ADMIN_PASSWORD={{ semaphore_admin_password }}

# Security
SEMAPHORE_ACCESS_KEY_ENCRYPTION={{ semaphore_access_key_encryption }}

# Web configuration
SEMAPHORE_WEB_ROOT={{ semaphore_external_url }}

# General
TZ={{ timezone | default('America/Toronto') }}

# Git credential configuration for submodule cloning
# Points to a git config file that configures credential storage
GIT_CONFIG_GLOBAL=/data/.gitconfig
GIT_TERMINAL_PROMPT=0
